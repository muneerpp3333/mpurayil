{
  "name": "muneer-architect",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3005",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "validate:post": "node scripts/validate-post.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "manifest": "node scripts/generate-blog-manifest.mjs",
    "generate:articles": "node scripts/generate-articles.mjs",
    "enhance:articles": "node scripts/enhance-articles.mjs",
    "prebuild": "node scripts/generate-blog-manifest.mjs && node scripts/generate-sitemap.mjs",
    "deploy": "bun run build && bunx wrangler pages deploy dist --project-name=mpurayil-com --commit-dirty=true"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "gray-matter": "^4.0.3",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^7.13.0",
    "highlight.js": "^11.11.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
